{
  "permissions": {
    "allow": [
      "Bash(npm test *)",
      "Bash(node --test *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile .claude/hooks/rtk-rewrite.ps1",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile .claude/hooks/safety-guard.ps1",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
